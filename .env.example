# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=store_intelligence
POSTGRES_USER=si_user
POSTGRES_PASSWORD=si_pass

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://si_user:si_pass@localhost:5432/store_intelligence
LOG_LEVEL=INFO

# ── Detection ─────────────────────────────────────────────────────────────────
# HSV upper-body hue for staff uniform (used by StaffClassifier)
STAFF_COLOR_HEX=1A6B3C
STAFF_COLOR_TOLERANCE=30

# Re-ID
REID_SIMILARITY_THRESHOLD=0.75
REID_BUFFER_MINUTES=10

# Tracking
ENTRY_THRESHOLD_FRAMES=3
DETECTION_SAMPLE_FPS=5
BILLING_SAMPLE_FPS=3
CONFIDENCE_THRESHOLD=0.3

# ── Dashboard ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
